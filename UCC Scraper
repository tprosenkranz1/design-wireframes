function renderFiling(f, subId) {
  const statusMap = { active:'Active', terminated:'Terminated', lapsed:'Lapsed/Expired', unknown:'Unknown' };
  const statusCls = { active:'status-active', terminated:'status-terminated', lapsed:'status-lapsed', unknown:'status-unknown' };
  const state = STATES.find(s => s.c === f.state);
  return `
    <div class="filing-card">
      <div class="filing-card-header">
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          ${f.state ? `<span class="filing-state-badge">${f.state}</span>` : ''}
          <span class="filing-num">Filing #${esc(f.filingNumber || 'N/A')}</span>
          <span class="status-pill ${statusCls[f.status] || 'status-unknown'}">${statusMap[f.status] || 'Unknown'}</span>
        </div>
        <div style="display:flex;gap:6px">
          ${f.state ? `<a href="${STATES.find(s=>s.c===f.state)?.url||'#'}" target="_blank" class="btn btn-secondary btn-sm">&#128279; View Portal</a>` : ''}
          <button class="btn btn-danger btn-sm" onclick="deleteFiling('${subId}','${f.id}')">&#128465;</button>
        </div>
      </div>
      <div class="filing-card-body">
        <div class="filing-grid">
          <div class="filing-field"><label>Debtor Name</label><span>${esc(f.debtor||'—')}</span></div>
          <div class="filing-field"><label>Secured Party</label><span>${esc(f.securedParty||'—')}</span></div>
          <div class="filing-field"><label>Filing Date</label><span>${fmt(f.filingDate)}</span></div>
          <div class="filing-field"><label>Expiration Date</label><span>${fmt(f.expirationDate)}</span></div>
          ${f.collateral ? `<div class="filing-field full"><label>Collateral / Description</label><span>${esc(f.collateral)}</span></div>` : ''}
          ${f.notes ? `<div class="filing-field full"><label>Notes</label><span>${esc(f.notes)}</span></div>` : ''}
        </div>
      </div>
    </div>
  `;
}

// ============================================================
// STATE MODAL
// ============================================================
function openStateModal(subId, stateCode) {
  const sub = subs.find(s => s.id === subId);
  const state = STATES.find(s => s.c === stateCode);
  if (!sub || !state) return;
  const current = sub.states[stateCode];

  showModal(`
    <div class="modal-header">
      <div class="modal-title">&#127968; ${state.n} (${state.c}) &#8212; UCC Search</div>
      <button class="modal-close" onclick="closeModal()">&#10005;</button>
    </div>
    <div class="modal-body">
      <div style="margin-bottom:14px">
        <a href="${state.url}" target="_blank" class="btn btn-primary" style="width:100%;justify-content:center;font-size:13px;padding:10px">
          &#128279; Open ${state.n} Secretary of State UCC Portal
        </a>
        <div style="font-size:11px;color:var(--gray-400);text-align:center;margin-top:5px">Opens in a new tab. Search for <strong>${esc(sub.name)}</strong> in the portal, then return to record the result below.</div>
      </div>
      <div style="border-top:1px solid var(--gray-200);padding-top:14px">
        <div class="state-action-title">Record Search Result</div>
        <div class="state-action-sub">What did you find for <strong>${esc(sub.name)}</strong> in ${state.n}?</div>
        <div class="action-opts">
          <button class="action-opt${current==='clear'?' selected':''}" onclick="setStateStatus('${subId}','${stateCode}','clear')">
            <span class="opt-icon">&#9989;</span>
            <span class="opt-label">No Filings Found</span>
            <span class="opt-desc">Searched successfully &#8212; name is clear</span>
          </button>
          <button class="action-opt${current==='filings'?' selected':''}" onclick="setStateStatus('${subId}','${stateCode}','filings')">
            <span class="opt-icon">&#9888;&#65039;</span>
            <span class="opt-label">Filings Found</span>
            <span class="opt-desc">UCC filings exist &#8212; record details below</span>
          </button>
          <button class="action-opt${current==='inaccessible'?' selected':''}" onclick="setStateStatus('${subId}','${stateCode}','inaccessible')">
            <span class="opt-icon">&#128683;</span>
            <span class="opt-label">Could Not Access</span>
            <span class="opt-desc">Portal unavailable, requires fee, or login needed</span>
          </button>
          <button class="action-opt${!current?' selected':''}" onclick="setStateStatus('${subId}','${stateCode}',null)">
            <span class="opt-icon">&#8634;&#65039;</span>
            <span class="opt-label">Reset / Not Searched</span>
            <span class="opt-desc">Clear this state's status</span>
          </button>
        </div>
      </div>
      ${current === 'filings' ? `
      <div style="margin-top:14px;border-top:1px solid var(--gray-200);padding-top:14px">
        <div style="font-size:12px;color:var(--gray-600);margin-bottom:10px">&#128073; Add the filing details using the <strong>"+ Add Filing"</strong> button in the main view, and select <strong>${state.c}</strong> as the state.</div>
        <button class="btn btn-primary" style="width:100%;justify-content:center" onclick="closeModal();openAddFiling('${subId}','${stateCode}')">+ Add Filing Details for ${state.c}</button>
      </div>` : ''}
    </div>
  `);
}

function setStateStatus(subId, stateCode, status) {
  const sub = subs.find(s => s.id === subId);
  if (!sub) return;
  if (status === null) { delete sub.states[stateCode]; }
  else { sub.states[stateCode] = status; }
  save();
  closeModal();
  renderDetail(sub);
  renderList();
  toast(status ? `${stateCode}: marked as "${status}"` : `${stateCode}: status cleared`);
}

// ============================================================
// ADD FILING MODAL
// ============================================================
function openAddFiling(subId, preState) {
  showModal(`
    <div class="modal-header">
      <div class="modal-title">&#128196; Add UCC Filing</div>
      <button class="modal-close" onclick="closeModal()">&#10005;</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">State *</label>
          <select class="form-control" id="f-state">
            <option value="">-- Select State --</option>
            ${STATES.map(s => `<option value="${s.c}"${preState===s.c?' selected':''}>${s.c} &#8212; ${s.n}</option>`).join('')}
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Filing Number</label>
          <input class="form-control" id="f-num" type="text" placeholder="e.g. 2024-123456">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Filing Status *</label>
          <select class="form-control" id="f-status">
            <option value="active">Active</option>
            <option value="terminated">Terminated</option>
            <option value="lapsed">Lapsed / Expired</option>
            <option value="unknown">Unknown</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Debtor Name</label>
          <input class="form-control" id="f-debtor" type="text" placeholder="Name on the filing">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Secured Party / Creditor</label>
        <input class="form-control" id="f-secured" type="text" placeholder="Lender, creditor, or lienholder name">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Filing Date</label>
          <input class="form-control" id="f-filed" type="date">
        </div>
        <div class="form-group">
          <label class="form-label">Expiration Date</label>
          <input class="form-control" id="f-expires" type="date">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Collateral Description</label>
        <textarea class="form-control" id="f-collateral" placeholder="Describe the collateral listed in the filing..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Internal Notes</label>
        <textarea class="form-control" id="f-notes" placeholder="Any additional notes or context..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="saveFiling('${subId}')">Save Filing</button>
    </div>
  `);
}

function saveFiling(subId) {
  const sub = subs.find(s => s.id === subId);
  if (!sub) return;
  const state = document.getElementById('f-state').value;
  const status = document.getElementById('f-status').value;
  if (!state) { toast('Please select a state'); return; }
  const filing = {
    id: uid(),
    state,
    filingNumber: document.getElementById('f-num').value.trim(),
    status,
    debtor: document.getElementById('f-debtor').value.trim(),
    securedParty: document.getElementById('f-secured').value.trim(),
    filingDate: document.getElementById('f-filed').value,
    expirationDate: document.getElementById('f-expires').value,
    collateral: document.getElementById('f-collateral').value.trim(),
    notes: document.getElementById('f-notes').value.trim()
  };
  if (!sub.filings) sub.filings = [];
  sub.filings.push(filing);
  // Auto-mark state as filings found
  sub.states[state] = 'filings';
  save();
  closeModal();
  renderDetail(sub);
  renderList();
  toast('Filing saved for ' + state);
}

function deleteFiling(subId, filingId) {
  const sub = subs.find(s => s.id === subId);
  if (!sub) return;
  if (!confirm('Delete this filing record?')) return;
  sub.filings = sub.filings.filter(f => f.id !== filingId);
  save();
  renderDetail(sub);
  renderList();
  toast('Filing removed');
}

function deleteSub(subId) {
  if (!confirm('Remove this subcontractor and all its data?')) return;
  subs = subs.filter(s => s.id !== subId);
  selectedId = null;
  save();
  renderList();
  document.getElementById('right-panel').innerHTML = `
    <div class="empty-state">
      <div class="empty-icon">&#128269;</div>
      <div class="empty-title">Select a Subcontractor</div>
      <div class="empty-sub">Select a subcontractor on the left to view UCC details.</div>
    </div>`;
  toast('Subcontractor removed');
}

function saveNotes(subId, val) {
  const sub = subs.find(s => s.id === subId);
  if (!sub) return;
  sub.notes = val;
  save();
}

// ============================================================
// EXPORT
// ============================================================
function exportCSV() {
  if (!subs.length) { toast('No data to export'); return; }
  const rows = [['Name','Overall Status','States Searched','States Clear','Inaccessible','Filing Count','Filing State','Filing #','Filing Status','Debtor','Secured Party','Filing Date','Expiration','Collateral','Notes']];
  subs.forEach(sub => {
    const stateVals = sub.states || {};
    const status = getStatus(sub);
    const searched = Object.keys(stateVals).length;
    const clear = Object.values(stateVals).filter(v=>v==='clear').length;
    const inac = Object.values(stateVals).filter(v=>v==='inaccessible').length;
    const filings = sub.filings || [];
    if (!filings.length) {
      rows.push([sub.name, getStatusLabel(status), searched, clear, inac, 0, '', '', '', '', '', '', '', '', sub.notes || '']);
    } else {
      filings.forEach(f => {
        rows.push([sub.name, getStatusLabel(status), searched, clear, inac, filings.length, f.state||'', f.filingNumber||'', f.status||'', f.debtor||'', f.securedParty||'', f.filingDate||'', f.expirationDate||'', f.collateral||'', f.notes||'']);
      });
    }
  });
  const csv = rows.map(r => r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
  a.download = 'ucc-tracker-export-' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
  toast('Exported CSV');
}

function clearAll() {
  if (!confirm('Delete ALL subcontractors and data? This cannot be undone.')) return;
  subs = [];
  selectedId = null;
  save();
  renderList();
  document.getElementById('right-panel').innerHTML = `
    <div class="empty-state">
      <div class="empty-icon">&#128269;</div>
      <div class="empty-title">All Clear</div>
      <div class="empty-sub">All data has been cleared.</div>
    </div>`;
  toast('All data cleared');
}

// ============================================================
// MODAL HELPERS
// ============================================================
function showModal(html) {
  document.getElementById('modal-box').innerHTML = html;
  document.getElementById('modal-overlay').style.display = 'flex';
}
function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }
function closeModalOnBg(e) { if (e.target === document.getElementById('modal-overlay')) closeModal(); }

// ============================================================
// TOAST
// ============================================================
let toastTimer;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2200);
}

// ============================================================
// UTILS
// ============================================================
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ============================================================
// INIT
// ============================================================
renderList();
if (subs.length) selectSub(subs[0].id);
</script>
