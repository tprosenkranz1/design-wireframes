  const searchedCount = Object.keys(stateVals).length;
  const clearCount = Object.values(stateVals).filter(v => v === 'clear').length;
  const filingCount = (sub.filings || []).length;
  const inaccessibleCount = Object.values(stateVals).filter(v => v === 'inaccessible').length;
  const filingStateCount = Object.values(stateVals).filter(v => v === 'filings').length;

  const badgeCls = { pending:'badge-pending', clear:'badge-clear', filings:'badge-filings', partial:'badge-partial' }[st] || 'badge-pending';

  panel.innerHTML = `
    <div class="detail-header">
      <div>
        <div class="detail-name">${esc(sub.name)}</div>
        <div class="detail-date">Added ${fmt(sub.added)} &nbsp;&#183;&nbsp; <span class="badge ${badgeCls}">${getStatusLabel(st)}</span></div>
      </div>
      <div class="detail-actions">
        <button class="btn btn-primary" onclick="openAddFiling('${sub.id}')">+ Add Filing</button>
        <button class="btn btn-danger btn-sm" onclick="deleteSub('${sub.id}')">&#128465; Remove</button>
      </div>
    </div>

    <!-- SUMMARY CARDS -->
    <div class="summary-grid">
      <div class="summary-card">
        <div class="summary-label">States Searched</div>
        <div class="summary-value">${searchedCount}<span style="font-size:13px;color:var(--gray-400);font-weight:400">/50</span></div>
      </div>
      <div class="summary-card">
        <div class="summary-label">UCC Filings Found</div>
        <div class="summary-value ${filingCount ? 'red' : ''}">${filingCount}</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">States Clear</div>
        <div class="summary-value ${clearCount && !filingCount ? 'green' : ''}">${clearCount}</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Inaccessible</div>
        <div class="summary-value ${inaccessibleCount ? 'yellow' : ''}">${inaccessibleCount}</div>
      </div>
    </div>

    ${inaccessibleCount ? `
    <div class="inaccessible-alert">
      <span style="font-size:16px">&#9888;</span>
      <span><strong>${inaccessibleCount} state${inaccessibleCount!==1?'s':''} could not be accessed</strong> during this search. Results may be incomplete. Consider contacting these state offices directly or using a commercial UCC search service.</span>
    </div>` : ''}

    <!-- STATE SEARCH GRID -->
    <div class="section">
      <div class="section-header">
        <div class="section-title">State UCC Search &#8212; All 50 States</div>
        <div style="font-size:11px;color:var(--gray-500)">Click any state to open its Secretary of State portal</div>
      </div>
      <div class="section-body">
        <div class="state-legend">
          <div class="legend-item"><div class="legend-dot" style="background:#e5e7eb;border:1px solid #d1d5db"></div>Not Yet Searched</div>
          <div class="legend-item"><div class="legend-dot" style="background:#d1fae5;border:1px solid #6ee7b7"></div>Searched &#8212; Clear</div>
          <div class="legend-item"><div class="legend-dot" style="background:#fee2e2;border:1px solid #fca5a5"></div>Filings Found</div>
          <div class="legend-item"><div class="legend-dot" style="background:#f3f4f6;border:1px solid #d1d5db"></div>Inaccessible</div>
        </div>
        <div class="state-grid">
          ${STATES.map(s => {
            const sv = stateVals[s.c];
            let cls = '';
            let statusTxt = '';
            if (sv === 'clear') { cls = 's-clear'; statusTxt = '&#10003; Clear'; }
            else if (sv === 'filings') { cls = 's-filings'; statusTxt = '&#9679; Filings'; }
            else if (sv === 'inaccessible') { cls = 's-inaccessible'; statusTxt = '&#9888; N/A'; }
            return `<button class="state-btn ${cls}" onclick="openStateModal('${sub.id}','${s.c}')">
              <span class="state-code">${s.c}</span>
              <span class="state-lbl">${s.n}</span>
              ${statusTxt ? `<div class="state-status">${statusTxt}</div>` : ''}
            </button>`;
          }).join('')}
        </div>
      </div>
    </div>

    <!-- FILINGS -->
    <div class="section">
      <div class="section-header">
        <div class="section-title">UCC Filings &nbsp;<span class="count-badge ${filingCount ? 'red' : ''}">${filingCount}</span></div>
        <button class="btn btn-primary btn-sm" onclick="openAddFiling('${sub.id}')">+ Add Filing</button>
      </div>
      <div class="section-body" style="padding: ${filingCount ? '14px 16px' : '0'}">
        ${filingCount === 0 ? `<div class="no-filings">&#128196; No UCC filings recorded for this subcontractor.<br><span style="font-size:11px">Use the state buttons above to search, then add any findings here.</span></div>` : ''}
