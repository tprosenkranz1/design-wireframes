let subs = JSON.parse(localStorage.getItem('ucc_subs') || '[]');
let selectedId = null;
let filterVal = '';

function save() { localStorage.setItem('ucc_subs', JSON.stringify(subs)); }

function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2); }

function fmt(dt) { if (!dt) return '—'; return new Date(dt+'T00:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}); }

// ============================================================
// ADD / IMPORT
// ============================================================
function addSub() {
  const inp = document.getElementById('name-input');
  const name = inp.value.trim();
  if (!name) { toast('Please enter a name'); return; }
  if (subs.find(s => s.name.toLowerCase() === name.toLowerCase())) { toast('That name already exists'); return; }
  const sub = { id: uid(), name, added: new Date().toISOString().slice(0,10), states: {}, filings: [], notes: '' };
  subs.unshift(sub);
  save();
  inp.value = '';
  renderList();
  selectSub(sub.id);
  toast('Added: ' + name);
}

function importCSV(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const lines = ev.target.result.split('\n').map(l => l.trim()).filter(Boolean);
    let added = 0, skipped = 0;
    lines.forEach((line, i) => {
      if (i === 0 && /^(name|subcontractor|company|vendor|debtor)/i.test(line.split(',')[0])) return;
      const name = line.split(',')[0].replace(/^"|"$/g,'').trim();
      if (!name) return;
      if (subs.find(s => s.name.toLowerCase() === name.toLowerCase())) { skipped++; return; }
      subs.push({ id: uid(), name, added: new Date().toISOString().slice(0,10), states: {}, filings: [], notes: '' });
      added++;
    });
    save();
    renderList();
    toast(`Imported ${added} names${skipped ? ', ' + skipped + ' duplicates skipped' : ''}`);
    e.target.value = '';
  };
  reader.readAsText(file);
}

function filterSubs(val) { filterVal = val.toLowerCase(); renderList(); }

// ============================================================
// RENDER LIST
// ============================================================
function getStatus(sub) {
  const stateVals = Object.values(sub.states);
  if (!stateVals.length) return 'pending';
  const hasFilings = sub.filings && sub.filings.length > 0;
  const hasInaccessible = stateVals.some(s => s === 'inaccessible');
  const allSearched = stateVals.length >= 50;
  if (hasFilings && hasInaccessible) return 'partial';
  if (hasFilings) return 'filings';
  if (hasInaccessible && !hasFilings) return 'partial';
  if (!hasFilings && stateVals.some(s => s === 'clear')) return 'clear';
  return 'pending';
}

function getStatusLabel(st) {
  return {pending:'Pending',clear:'All Clear',filings:'Filings Found',partial:'Incomplete / Issues'}[st] || st;
}

function renderList() {
  const container = document.getElementById('sub-list');
  const filtered = subs.filter(s => !filterVal || s.name.toLowerCase().includes(filterVal));

  if (!subs.length) {
    container.innerHTML = '<div class="sub-list-empty">No subcontractors yet.<br>Add a name or import a CSV.</div>';
    return;
  }
  if (!filtered.length) {
    container.innerHTML = '<div class="sub-list-empty">No matches found.</div>';
    return;
  }

  container.innerHTML = filtered.map(sub => {
    const st = getStatus(sub);
    const stateCount = Object.keys(sub.states).length;
    const filingCount = (sub.filings || []).length;
    const badgeCls = { pending:'badge-pending', clear:'badge-clear', filings:'badge-filings', partial:'badge-partial' }[st] || 'badge-pending';
    return `<div class="sub-item${selectedId===sub.id?' active':''}" onclick="selectSub('${sub.id}')">
      <div class="sub-name">${esc(sub.name)}</div>
      <div class="sub-meta">
        <span class="badge ${badgeCls}">${getStatusLabel(st)}</span>
        ${stateCount ? `<span style="font-size:10px;color:var(--gray-400)">${stateCount}/50 states</span>` : ''}
        ${filingCount ? `<span style="font-size:10px;color:var(--danger);font-weight:600">${filingCount} filing${filingCount!==1?'s':''}</span>` : ''}
      </div>
    </div>`;
  }).join('');
}

// ============================================================
// DETAIL VIEW
// ============================================================
function selectSub(id) {
  selectedId = id;
  renderList();
  const sub = subs.find(s => s.id === id);
  if (!sub) return;
  renderDetail(sub);
}

function renderDetail(sub) {
