<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UCC Filing Tracker</title>
  <style>
    :root {
      --primary: #1a56db;
      --primary-light: #eff6ff;
      --primary-dark: #1e429f;
      --success: #057a55;
      --success-light: #d1fae5;
      --warning: #c27803;
      --warning-light: #fef3c7;
      --danger: #c81e1e;
      --danger-light: #fee2e2;
      --gray-50: #f9fafb;
      --gray-100: #f3f4f6;
      --gray-200: #e5e7eb;
      --gray-300: #d1d5db;
      --gray-400: #9ca3af;
      --gray-500: #6b7280;
      --gray-600: #4b5563;
      --gray-700: #374151;
      --gray-800: #1f2937;
      --gray-900: #111827;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--gray-100);
      color: var(--gray-800);
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    /* HEADER */
    .header {
      background: var(--gray-900);
      color: white;
      padding: 10px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
      border-bottom: 2px solid var(--primary);
    }
    .header-left h1 { font-size: 17px; font-weight: 700; letter-spacing: -0.3px; }
    .header-left p { font-size: 11px; color: var(--gray-400); margin-top: 1px; }
    .header-actions { display: flex; gap: 8px; }
    /* BUTTONS */
    .btn {
      padding: 7px 13px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
      transition: all 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }
    .btn-primary { background: var(--primary); color: white; }
    .btn-primary:hover { background: var(--primary-dark); }
    .btn-secondary { background: white; color: var(--gray-700); border: 1px solid var(--gray-300); }
    .btn-secondary:hover { background: var(--gray-50); }
    .btn-danger { background: var(--danger-light); color: var(--danger); border: 1px solid #fca5a5; }
    .btn-danger:hover { background: #fecaca; }
    .btn-success { background: var(--success-light); color: var(--success); border: 1px solid #6ee7b7; }
    .btn-success:hover { background: #a7f3d0; }
    .btn-sm { padding: 5px 9px; font-size: 11px; }
    /* MAIN LAYOUT */
    .main { display: flex; flex: 1; overflow: hidden; }
    /* LEFT PANEL */
    .left-panel {
      width: 270px;
      background: white;
      border-right: 1px solid var(--gray-200);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }
    .panel-header {
      padding: 10px 14px 8px;
      border-bottom: 1px solid var(--gray-200);
      background: var(--gray-50);
    }
    .panel-title {
      font-size: 11px;
      font-weight: 700;
      color: var(--gray-500);
      text-transform: uppercase;
      letter-spacing: 0.7px;
      margin-bottom: 8px;
    }
    .input-row { display: flex; gap: 5px; margin-bottom: 6px; }
    .input-field {
      flex: 1;
      padding: 7px 9px;
      border: 1px solid var(--gray-300);
      border-radius: 6px;
      font-size: 12px;
      outline: none;
    }
    .input-field:focus { border-color: var(--primary); box-shadow: 0 0 0 2px rgba(26,86,219,0.12); }
    .csv-label {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      padding: 6px;
      border-radius: 6px;
      border: 1px dashed var(--gray-300);
      font-size: 11px;
      color: var(--gray-500);
      cursor: pointer;
      transition: all 0.15s;
    }
    .csv-label:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
    .search-box {
      padding: 6px 10px;
      border-bottom: 1px solid var(--gray-200);
    }
    .search-box input {
      width: 100%;
      padding: 6px 9px;
      border: 1px solid var(--gray-200);
      border-radius: 6px;
      font-size: 12px;
      outline: none;
    }
    .search-box input:focus { border-color: var(--primary); }
    /* SUB LIST */
    .sub-list { flex: 1; overflow-y: auto; }
    .sub-item {
      padding: 10px 14px;
      border-bottom: 1px solid var(--gray-100);
      cursor: pointer;
      transition: background 0.1s;
      border-left: 3px solid transparent;
    }
    .sub-item:hover { background: var(--gray-50); }
    .sub-item.active { background: var(--primary-light); border-left-color: var(--primary); }
    .sub-name { font-size: 13px; font-weight: 500; color: var(--gray-800); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sub-meta { display: flex; align-items: center; gap: 5px; margin-top: 4px; flex-wrap: wrap; }
    /* BADGES */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 1px 6px;
      border-radius: 9999px;
      font-size: 10px;
      font-weight: 600;
    }
    .badge-pending { background: var(--gray-100); color: var(--gray-600); }
    .badge-clear { background: var(--success-light); color: var(--success); }
    .badge-filings { background: var(--danger-light); color: var(--danger); }
    .badge-partial { background: var(--warning-light); color: var(--warning); }
    .badge-inaccessible { background: var(--gray-100); color: var(--gray-500); }
    /* RIGHT PANEL */
    .right-panel { flex: 1; overflow-y: auto; padding: 18px 22px; background: var(--gray-50); }
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: var(--gray-400);
      text-align: center;
    }
    .empty-icon { font-size: 52px; margin-bottom: 14px; }
    .empty-title { font-size: 16px; font-weight: 600; color: var(--gray-600); margin-bottom: 6px; }
    .empty-sub { font-size: 13px; }
    /* DETAIL VIEW */
    .detail-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .detail-name { font-size: 20px; font-weight: 700; color: var(--gray-900); }
    .detail-date { font-size: 11px; color: var(--gray-400); margin-top: 3px; }
    .detail-actions { display: flex; gap: 6px; flex-shrink: 0; margin-left: 12px; }
    /* SUMMARY CARDS */
    .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 18px; }
    .summary-card {
      background: white;
      border: 1px solid var(--gray-200);
      border-radius: 8px;
      padding: 12px 14px;
    }
    .summary-label { font-size: 10px; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .summary-value { font-size: 22px; font-weight: 800; color: var(--gray-900); }
    .summary-value.red { color: var(--danger); }
    .summary-value.green { color: var(--success); }
    .summary-value.yellow { color: var(--warning); }
    /* SECTION */
    .section {
      background: white;
      border: 1px solid var(--gray-200);
      border-radius: 8px;
      margin-bottom: 16px;
      overflow: hidden;
    }
    .section-header {
      padding: 12px 16px;
      border-bottom: 1px solid var(--gray-200);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--gray-50);
    }
    .section-title { font-size: 13px; font-weight: 600; color: var(--gray-700); }
    .section-body { padding: 14px 16px; }
    /* STATE GRID */
    .state-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(88px, 1fr)); gap: 6px; }
    .state-btn {
      padding: 7px 6px;
      border-radius: 6px;
      border: 1px solid var(--gray-200);
      background: white;
      cursor: pointer;
      font-size: 11px;
      text-align: center;
      transition: all 0.15s;
    }
    .state-btn:hover { border-color: var(--primary); background: var(--primary-light); }
    .state-btn.s-clear { background: var(--success-light); border-color: #6ee7b7; }
    .state-btn.s-filings { background: var(--danger-light); border-color: #fca5a5; }
    .state-btn.s-inaccessible { background: var(--gray-100); border-color: var(--gray-300); }
    .state-code { font-weight: 700; font-size: 12px; display: block; color: var(--gray-800); }
    .state-lbl { font-size: 10px; color: var(--gray-500); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .state-status { font-size: 9px; margin-top: 2px; font-weight: 600; }
    .s-clear .state-status { color: var(--success); }
    .s-filings .state-status { color: var(--danger); }
    .s-inaccessible .state-status { color: var(--gray-400); }
    .state-legend { display: flex; gap: 14px; margin-bottom: 10px; flex-wrap: wrap; }
    .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--gray-600); }
    .legend-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }
    /* FILING CARDS */
    .no-filings { text-align: center; padding: 24px; color: var(--gray-400); font-size: 13px; }
    .filing-card {
      border: 1px solid var(--gray-200);
      border-radius: 8px;
      margin-bottom: 10px;
      overflow: hidden;
    }
    .filing-card-header {
      padding: 10px 14px;
      background: var(--gray-50);
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--gray-200);
      gap: 8px;
    }
    .filing-num { font-weight: 600; font-size: 13px; color: var(--gray-900); }
    .filing-state-badge {
      background: var(--primary);
      color: white;
      padding: 1px 7px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 700;
    }
    .filing-card-body { padding: 12px 14px; }
    .filing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .filing-field label { font-size: 10px; color: var(--gray-400); text-transform: uppercase; letter-spacing: 0.4px; display: block; margin-bottom: 2px; }
    .filing-field span { font-size: 12px; color: var(--gray-800); }
    .filing-field.full { grid-column: 1 / -1; }
    .status-pill {
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
    }
    .status-active { background: var(--danger-light); color: var(--danger); }
    .status-terminated { background: var(--success-light); color: var(--success); }
    .status-lapsed { background: var(--warning-light); color: var(--warning); }
    .status-unknown { background: var(--gray-100); color: var(--gray-600); }
    .inaccessible-alert {
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: 6px;
      padding: 10px 12px;
      font-size: 12px;
      color: #92400e;
      margin-bottom: 14px;
      display: flex;
      gap: 8px;
      align-items: flex-start;
    }
    /* MODAL */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 999;
    }
    .modal {
      background: white;
      border-radius: 10px;
      width: 520px;
      max-width: 95vw;
      max-height: 92vh;
      overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    }
    .modal-header {
      padding: 14px 18px;
      border-bottom: 1px solid var(--gray-200);
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      background: white;
      z-index: 1;
    }
    .modal-title { font-size: 15px; font-weight: 600; }
    .modal-close { background: none; border: none; cursor: pointer; font-size: 18px; color: var(--gray-400); padding: 2px 6px; border-radius: 4px; }
    .modal-close:hover { background: var(--gray-100); color: var(--gray-700); }
    .modal-body { padding: 18px; }
    .modal-footer { padding: 14px 18px; border-top: 1px solid var(--gray-200); display: flex; justify-content: flex-end; gap: 8px; }
    .form-group { margin-bottom: 12px; }
    .form-label { display: block; font-size: 12px; font-weight: 500; color: var(--gray-700); margin-bottom: 4px; }
    .form-control {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid var(--gray-300);
      border-radius: 6px;
      font-size: 13px;
      outline: none;
      transition: border-color 0.15s;
    }
    .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 2px rgba(26,86,219,0.1); }
    textarea.form-control { resize: vertical; min-height: 72px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    /* STATE MODAL */
    .state-action-title { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
    .state-action-sub { font-size: 12px; color: var(--gray-500); margin-bottom: 14px; }
    .action-opts { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .action-opt {
      padding: 10px 12px;
      border-radius: 8px;
      border: 2px solid var(--gray-200);
      background: white;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
      transition: all 0.15s;
      text-align: left;
    }
    .action-opt:hover { border-color: var(--primary); background: var(--primary-light); }
    .action-opt .opt-icon { font-size: 18px; display: block; margin-bottom: 4px; }
    .action-opt .opt-label { font-weight: 600; font-size: 12px; display: block; }
    .action-opt .opt-desc { font-size: 11px; color: var(--gray-500); margin-top: 1px; display: block; }
    /* TOAST */
    .toast {
      position: fixed;
      bottom: 18px;
      right: 18px;
      background: var(--gray-900);
      color: white;
      padding: 9px 14px;
      border-radius: 8px;
      font-size: 12px;
      z-index: 9999;
      opacity: 0;
      transition: opacity 0.25s;
      pointer-events: none;
    }
    .toast.show { opacity: 1; }
    /* SCROLLBAR */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--gray-300); border-radius: 3px; }
    /* NOTES AREA */
    .notes-area {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid var(--gray-200);
      border-radius: 6px;
      font-size: 12px;
      outline: none;
      resize: none;
      min-height: 52px;
      color: var(--gray-700);
    }
    .notes-area:focus { border-color: var(--primary); }
    .count-badge { font-size: 11px; font-weight: 600; background: var(--gray-100); color: var(--gray-600); padding: 1px 6px; border-radius: 9999px; }
    .count-badge.red { background: var(--danger-light); color: var(--danger); }
    .count-badge.yellow { background: var(--warning-light); color: var(--warning); }
    #hidden-csv { display: none; }
    .sub-list-empty { text-align: center; padding: 28px 14px; color: var(--gray-400); font-size: 12px; }
  </style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-left">
    <h1>&#128196; UCC Filing Tracker</h1>
    <p>Subcontractor UCC Lien Search &amp; Tracking</p>
  </div>
  <div class="header-actions">
    <button class="btn btn-secondary" onclick="exportCSV()">&#8659; Export CSV</button>
    <button class="btn btn-secondary" onclick="clearAll()" style="color:#c81e1e;">&#128465; Clear All</button>
  </div>
</div>

<!-- MAIN -->
<div class="main">
  <!-- LEFT PANEL -->
  <div class="left-panel">
    <div class="panel-header">
      <div class="panel-title">Subcontractors</div>
      <div class="input-row">
        <input class="input-field" id="name-input" type="text" placeholder="Enter name..." onkeydown="if(event.key==='Enter')addSub()">
        <button class="btn btn-primary" onclick="addSub()">+&nbsp;Add</button>
      </div>
      <label class="csv-label" for="hidden-csv">&#128196; Import CSV (Name column)</label>
      <input type="file" id="hidden-csv" accept=".csv" onchange="importCSV(event)">
    </div>
    <div class="search-box">
      <input type="text" placeholder="&#128269; Filter subcontractors..." oninput="filterSubs(this.value)">
    </div>
    <div class="sub-list" id="sub-list"></div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="right-panel" id="right-panel">
    <div class="empty-state">
      <div class="empty-icon">&#128269;</div>
      <div class="empty-title">Select a Subcontractor</div>
      <div class="empty-sub">Add names on the left, then select one to begin<br>searching UCC filings across all 50 states.</div>
    </div>
  </div>
</div>

<!-- MODALS -->
<div id="modal-overlay" class="overlay" style="display:none;" onclick="closeModalOnBg(event)">
  <div class="modal" id="modal-box"></div>
</div>

<div class="toast" id="toast"></div>

<script>
// ============================================================
// DATA
// ============================================================
const STATES = [
  {c:"AL",n:"Alabama",url:"https://arc-sos.state.al.us/CGI/UCCNAME.MBR/INPUT"},
